# Copy to `.env` and fill secrets before `docker compose up --build`.
# Docker Compose reads this file automatically from the repo root.

# ── Ports (host → container) ────────────────────────────
FRONTEND_PORT=3001
BACKEND_PORT=3000
PYTHON_PORT=8000
POSTGRES_PORT=5432

# ── Postgres ────────────────────────────────────────────
POSTGRES_USER=aura_user
POSTGRES_PASSWORD=aura_password
POSTGRES_DB=aura_db

# ── Backend ─────────────────────────────────────────────
NODE_ENV=production
# Must match the URL you open in the browser (CORS + cookies)
FRONTEND_ORIGIN=http://localhost:3001
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
# false = call Python; true = Nest stub (no Gemini needed)
BACKEND_USE_AI_STUB=false
PYTHON_SERVICE_TIMEOUT_MS=50000
RATE_LIMIT_PER_MINUTE=10
TRIAGE_BUDGET_PER_HOUR=60

# Mail (optional — password reset)
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Aura <noreply@aura.health>
MAIL_RESET_PASSWORD_PATH=/reset-password
MAIL_DEV_EXPOSE_TOKEN=false

# Integrations (optional)
EXA_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Python AI ───────────────────────────────────────────
GEMINI_API_KEY=
MODEL_NAME=gemini-2.5-flash
# 0 = real Gemini; 1 = deterministic stubs (smoke without API key)
PYTHON_USE_AI_STUB=0
LLM_TIMEOUT_SECONDS=45
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Frontend (build-time; rebuild after changing) ───────
# 0 = real Nest triage; 1 = Next local mock handlers
NEXT_PUBLIC_USE_MOCK=0
