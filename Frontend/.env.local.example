# NestJS API base URL (no trailing slash).
# Local:  http://localhost:3000
# Ngrok:  https://<subdomain>.ngrok-free.app
# Prod:   https://<your-api-host>
#
# Browser never calls this directly — Next.js rewrites /api-proxy/* → this URL
# so HttpOnly auth cookies stay on the frontend origin.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Backend must allow this frontend origin with credentials (exact match):
#   Dev:  FRONTEND_ORIGIN=http://localhost:3001
#   Prod: FRONTEND_ORIGIN=https://<your-vercel-domain>
# Also set COOKIE_SECURE=true in production HTTPS.

# 0 = real dashboard + triage (required for deploy / integration demos)
# 1 = mock triage/dashboard only (auth still hits real API)
NEXT_PUBLIC_USE_MOCK=0
