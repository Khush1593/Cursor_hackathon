# Real NestJS base (localhost or ngrok HTTPS). Browser never calls this
# directly — Next.js rewrites /api-proxy/* → this URL so HttpOnly cookies
# stay on localhost:3001 (required for cross-origin ngrok cookie auth).
NEXT_PUBLIC_API_URL=http://localhost:3000
# Example ngrok:
# NEXT_PUBLIC_API_URL=https://057a-183-83-240-116.ngrok-free.app

# Backend must allow this frontend origin with credentials:
# FRONTEND_ORIGIN=http://localhost:3001

# 1 = triage/dashboard use local mock (auth still hits real API)
# 0 = triage/dashboard call the real NestJS backend
NEXT_PUBLIC_USE_MOCK=1
