# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3001

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://aura_user:aura_password@localhost:5432/aura_db

# ── Auth (HTTP-only cookies — never put tokens in localStorage) ──
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
# Set COOKIE_SECURE=true in production (HTTPS). SameSite=None requires Secure.

# ── Mail (Nodemailer — password reset) ──────────────────
# Example (Gmail app password / Mailtrap / SES SMTP):
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Aura <noreply@aura.health>"
MAIL_RESET_PASSWORD_PATH=/reset-password
# When SMTP is unset, emails use Nodemailer JSON transport (logged only).
# Set true only in local dev to also return resetToken in the API response:
MAIL_DEV_EXPOSE_TOKEN=false

# ── AI service ──────────────────────────────────────────
PYTHON_SERVICE_URL=http://localhost:8000
USE_AI_STUB=true

# ── Integrations ────────────────────────────────────────
EXA_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Rate limiting ───────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
