# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3001

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://aura_user:aura_password@localhost:5432/aura_db

# ── Auth (HTTP-only cookies — never put tokens in localStorage) ──
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false

# ── Mail (Nodemailer — password reset) ──────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Aura <noreply@aura.health>"
MAIL_RESET_PASSWORD_PATH=/reset-password
MAIL_DEV_EXPOSE_TOKEN=false

# ── AI service ──────────────────────────────────────────
PYTHON_SERVICE_URL=http://localhost:8000
# Nest→Python fetch timeout (ms). Must exceed Python Gemini ceiling (~45s).
PYTHON_SERVICE_TIMEOUT_MS=50000
USE_AI_STUB=true

# ── Integrations ────────────────────────────────────────
EXA_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Rate limiting / triage budget ────────────────────────
RATE_LIMIT_PER_MINUTE=10
TRIAGE_BUDGET_PER_HOUR=60
