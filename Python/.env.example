GEMINI_API_KEY=your-gemini-api-key-here
MODEL_NAME=gemini-2.5-flash
# Set to 1 to skip the LLM and return deterministic stubs (useful for local smoke tests)
USE_AI_STUB=0
# Max seconds for a single Gemini call before Nest should hit its fallback
LLM_TIMEOUT_SECONDS=45

# ElevenLabs TTS (POST /tts, optional demo). Nest owns production TTS.
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
